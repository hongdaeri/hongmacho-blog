---
interface TagWithCount {
  tag: string;
  count: number;
}

interface Props {
  tags: TagWithCount[];
  selectedTag: string | null;
}

const { tags, selectedTag } = Astro.props;

const maxCount = Math.max(...tags.map(t => t.count), 1);
const getSize = (count: number) => {
  const min = 12;
  const max = 20;
  const ratio = count / maxCount;
  return min + (max - min) * ratio;
};
---

<nav class="tag-cloud">
  <div class="tag-cloud__title">태그</div>
  <div class="tag-cloud__list">
    {tags.map((item) => (
      <a
        href={`/blog?tag=${item.tag}`}
        class:list={['tag-cloud__item', { 'is-active': selectedTag === item.tag }]}
        style={`font-size: ${getSize(item.count)}px`}
      >
        #{item.tag}
        <span class="tag-cloud__count">{item.count}</span>
      </a>
    ))}
  </div>
</nav>

<style>
.tag-cloud {
  position: sticky;
  top: 88px;
  min-width: 200px;
}

.tag-cloud__title {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-tertiary);
  margin-bottom: 10px;
  padding: 0 8px;
}

.tag-cloud__list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.tag-cloud__item {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 4px 8px;
  border-radius: 6px;
  text-decoration: none;
  color: var(--text-secondary);
  font-weight: 500;
  transition: all 0.1s ease;
  white-space: nowrap;
}

.tag-cloud__item:hover {
  background: var(--surface-2, rgba(0,0,0,0.04));
  color: var(--text-primary);
}

.tag-cloud__item.is-active {
  background: var(--c-blue-10, rgba(0, 102, 255, 0.08));
  color: var(--c-blue-50, #0066ff);
  font-weight: 600;
}

.tag-cloud__count {
  font-size: 10px;
  color: var(--text-tertiary);
  font-weight: 600;
  font-family: monospace;
  opacity: 0.7;
}

.tag-cloud__item.is-active .tag-cloud__count {
  opacity: 1;
}

@container app (max-width: 860px) {
  .tag-cloud {
    position: static;
    min-width: auto;
  }

  .tag-cloud__list {
    gap: 6px;
  }
}
</style>
