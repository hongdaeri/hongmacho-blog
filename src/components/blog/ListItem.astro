---
import CategoryBadge from '../ui/CategoryBadge.astro';
import { formatDate } from '../../lib/utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, excerpt, category, tags, date, readTime } = post.data;
const slug = post.id;
const displayTags = tags.slice(0, 3);
---

<article class="list-item">
  <div class="list-item__header">
    <a href={`/blog/${slug}`} class="list-item__link">
      <h3 class="list-item__title">{title}</h3>
    </a>
  </div>
  <p class="list-item__excerpt">{excerpt}</p>
  <div class="list-item__footer">
    <div class="list-item__meta">
      <CategoryBadge category={category} />
      <time datetime={date} class="list-item__date">{formatDate(date)}</time>
      {readTime && <span class="list-item__read-time">{readTime}분 읽기</span>}
    </div>
    <div class="list-item__tags">
      {displayTags.map((tag) => (
        <a href={`/blog?tag=${tag}`} class="list-item__tag">#{tag}</a>
      ))}
    </div>
  </div>
</article>

<style>
.list-item {
  padding: 20px 0;
  border-bottom: 1px solid var(--border-subtle, rgba(0,0,0,0.08));
  transition: opacity 0.15s ease;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item:hover {
  opacity: 0.8;
}

.list-item__header {
  margin-bottom: 8px;
}

.list-item__link {
  text-decoration: none;
}

.list-item__title {
  font-size: 18px;
  font-weight: 700;
  line-height: 1.4;
  color: var(--text-primary);
  margin: 0;
  transition: color 0.15s ease;
}

.list-item__link:hover .list-item__title {
  color: var(--c-blue-50, #0066ff);
}

.list-item__excerpt {
  font-size: 14px;
  color: var(--text-secondary);
  line-height: 1.6;
  margin: 8px 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.list-item__footer {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
  margin-top: 10px;
}

.list-item__meta {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: var(--text-tertiary);
}

.list-item__date::before {
  content: '·';
  margin-right: 8px;
}

.list-item__read-time::before {
  content: '·';
  margin-right: 8px;
}

.list-item__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.list-item__tag {
  font-size: 11px;
  color: var(--text-tertiary);
  background: var(--surface-2, rgba(0,0,0,0.04));
  padding: 3px 8px;
  border-radius: 99px;
  text-decoration: none;
  transition: background 0.1s ease, color 0.1s ease;
}

.list-item__tag:hover {
  background: var(--c-blue-10, rgba(0, 102, 255, 0.08));
  color: var(--c-blue-50, #0066ff);
}
</style>
