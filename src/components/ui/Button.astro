---
interface Props {
  variant?: 'primary' | 'white' | 'ghost';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  disabled?: boolean;
}

const { variant = 'primary', href, type = 'button', class: className, disabled } = Astro.props;
---

{
  href ? (
    <a href={href} class:list={['btn', `btn--${variant}`, className]}>
      <slot />
    </a>
  ) : (
    <button
      type={type}
      disabled={disabled}
      class:list={['btn', `btn--${variant}`, className]}
    >
      <slot />
    </button>
  )
}
