---
import CategoryBadge from '../ui/CategoryBadge.astro';
import { formatDate } from '../../lib/utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, category, date, readTime, tags } = post.data;
---

<header class="article-header">
  <div class="article-header__meta-top">
    <CategoryBadge category={category} />
    <div class="article-header__date-info">
      <time datetime={date}>{formatDate(date)}</time>
      {readTime && <span class="article-header__read-time">· {readTime}분 읽기</span>}
    </div>
  </div>
  <h1 class="article-header__title">{title}</h1>
  {tags && tags.length > 0 && (
    <div class="article-header__tags">
      {tags.map((tag) => (
        <a href={`/blog?tag=${encodeURIComponent(tag)}`} class="article-header__tag">#{tag}</a>
      ))}
    </div>
  )}
  <div class="article-header__author">
    <div class="article-header__avatar" aria-hidden="true">홍</div>
    <div class="article-header__author-info">
      <span class="article-header__author-name">홍마초</span>
      <span class="article-header__author-sub">Software Engineer</span>
    </div>
  </div>
</header>

<style>
.article-header {
  margin-bottom: 48px;
  padding-bottom: 32px;
  border-bottom: 1px solid var(--border-subtle, rgba(0,0,0,0.08));
}

.article-header__meta-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 16px;
}

.article-header__date-info {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 13px;
  color: var(--text-tertiary);
}

.article-header__title {
  font-size: clamp(28px, 4vw, 40px);
  font-weight: 800;
  line-height: 1.25;
  letter-spacing: -0.03em;
  color: var(--text-primary);
  margin-bottom: 20px;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.article-header__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 24px;
}

.article-header__tag {
  font-size: 13px;
  color: var(--text-tertiary);
  background: var(--surface-2, rgba(0,0,0,0.04));
  padding: 3px 10px;
  border-radius: 99px;
  text-decoration: none;
  transition: color 0.1s, background 0.1s;
}

.article-header__tag:hover {
  color: var(--c-blue-50, #0066ff);
  background: var(--c-blue-10, rgba(0,102,255,0.08));
}

.article-header__author {
  display: flex;
  align-items: center;
  gap: 12px;
}

.article-header__avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: linear-gradient(135deg, #0066ff 0%, #6541F2 100%);
  color: white;
  font-size: 16px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.article-header__author-info {
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.article-header__author-name {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-primary);
}

.article-header__author-sub {
  font-size: 12px;
  color: var(--text-tertiary);
}
</style>
